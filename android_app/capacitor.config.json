{
  "appId": "com.toriscollection.app",
  "appName": "Toris Collection",
  "webDir": "www",
  "server": {
    "url": "https://toris-collection.onrender.com",
    "cleartext": false,
    "allowNavigation": [
      "toris-collection.onrender.com",
      "*.onrender.com"
    ]
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#ffffffff",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  }
}
